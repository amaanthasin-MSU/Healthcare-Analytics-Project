            <column caption='Sales per Store Perf. - Reference' datatype='real' default-format='c&quot;$ &quot;#,##0;(&quot;$ &quot;#,##0)' name='[LinPack_730333645072527257]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [Parameters].[LinPack_949819255619347265] &#13;&#10;WHEN &quot;CM_vs_PM&quot; THEN [LinPack_406171948951892571] &#13;&#10;WHEN &quot;CM_vs_PY&quot; THEN [LinPack_653269785666574634] &#13;&#10;WHEN &quot;ACT_vs_TGT&quot; THEN NULL &#13;&#10;WHEN &quot;CYTD_vs_PYTD&quot; THEN [LinPack_386932733309566273] &#13;&#10;WHEN &quot;YTDACT_vs_YTDTGT&quot; THEN NULL &#13;&#10;WHEN &quot;NONE&quot;  THEN NULL &#13;&#10;END' />
