              <calculation class='tableau' formula='CASE True&#13;&#10;&#13;&#10;WHEN [Parameters].[LinPack_949819255619347265]=&quot;CM_vs_PM&quot; or [Parameters].[LinPack_949819255619347265]=&quot;CM_vs_PY&quot; or [Parameters].[LinPack_949819255619347265]=&quot;ACT_vs_TGT&quot; THEN &#13;&#10;            COUNTD(IF [LinPack_112320563205440314] = [Parameters].[LinPack_661713406488724115] AND [LinPack_923155276951376517] = [Parameters].[LinPack_268298139370622864] THEN [Product Line] ELSE NULL END)&#13;&#10;&#13;&#10;WHEN [Parameters].[LinPack_949819255619347265]=&quot;CYTD_vs_PYTD&quot; or [Parameters].[LinPack_949819255619347265]=&quot;YTDACT_vs_YTDTGT&quot; THEN &#13;&#10;            COUNTD(IF [LinPack_112320563205440314] = [Parameters].[LinPack_661713406488724115] AND [LinPack_923155276951376517] &lt;= [Parameters].[LinPack_268298139370622864] THEN [Product Line] ELSE NULL END)&#13;&#10;&#13;&#10;WHEN [Parameters].[LinPack_949819255619347265]=&quot;NONE&quot;  THEN &#13;&#10;               NULL &#13;&#10;END' />
