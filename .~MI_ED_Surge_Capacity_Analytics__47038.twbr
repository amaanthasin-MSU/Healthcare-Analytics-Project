              <calculation class='tableau' formula='CASE [Parameters].[LinPack_949819255619347265] &#13;&#10;WHEN &quot;CM_vs_PM&quot; THEN [LinPack_074081860109431474] &#13;&#10;WHEN &quot;CM_vs_PY&quot; THEN [LinPack_074081860109431474] &#13;&#10;WHEN &quot;ACT_vs_TGT&quot; THEN  [LinPack_074081860109431474] &#13;&#10;WHEN &quot;CYTD_vs_PYTD&quot; THEN [LinPack_230355516704982224] &#13;&#10;WHEN &quot;YTDACT_vs_YTDTGT&quot; THEN [LinPack_230355516704982224]  &#13;&#10;WHEN &quot;NONE&quot;  THEN NULL &#13;&#10;END' />
