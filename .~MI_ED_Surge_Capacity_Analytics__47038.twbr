              <calculation class='tableau' formula='IF [Parameters].[LinPack_268298139370622864]=1 THEN &#13;&#10;[Parameters].[LinPack_661713406488724115]-1 &#13;&#10;ELSE &#13;&#10;[Parameters].[LinPack_661713406488724115] &#13;&#10;END' />
