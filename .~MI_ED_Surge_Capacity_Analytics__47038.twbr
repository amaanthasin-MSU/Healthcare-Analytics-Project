      <column caption='Store Filter' datatype='string' name='[Brand Filter (copy)_6364993702226935808]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Store]' />
        <desc>
          <formatted-text>
            <run>→</run>
          </formatted-text>
        </desc>
      </column>
      <column caption='Store Position' datatype='spatial' name='[Calculation_1013872902083829765]' role='measure' type='nominal'>
        <calculation class='tableau' formula='MAKEPOINT([Store Latitude],[Store Longitude])' />
      </column>
      <column caption='Total Sales Perf. - Value (for selected Store)' datatype='real' name='[Calculation_1241023230910562305 1]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MAX(If [Store Filter (copy)_1756403905605222402] THEN {INCLUDE [Store] : [LinPack_259808385027569986]} END)' />
        <desc>
          <formatted-text>
            <run>→</run>
          </formatted-text>
        </desc>
      </column>
      <column caption='Total Sales Perf. - Value (for selected Product)' datatype='real' name='[Calculation_1241023230910562305 2]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MAX(If [Store Filter (copy)_1756403905605222402 1] THEN {INCLUDE [Product] : [LinPack_259808385027569986]} END)' />
        <desc>
          <formatted-text>
            <run>→</run>
          </formatted-text>
        </desc>
      </column>
      <column caption='Total Sales Perf. - Value (for selected Product Line)' datatype='real' name='[Calculation_1241023230910562305]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MAX(If [Is Selected Store Type Flag (copy)_813744216047374336] THEN {INCLUDE [Product Line] : [LinPack_259808385027569986]} END)' />
        <desc>
          <formatted-text>
            <run>→</run>
          </formatted-text>
        </desc>
      </column>
      <column caption='Is Store or Product growing?' datatype='boolean' name='[Calculation_1318710302554902528]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='{FIXED [Selected Store or Business Line (copy)_845550866686013444] : [LinPack_216324288650019298]&gt;0}' />
      </column>
      <column caption='Business Line of selected Product' datatype='string' name='[Calculation_1602718552925081602 1]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='{MAX(If [Store Filter (copy)_1756403905605222402 1] THEN  [Product Line] END)}' />
      </column>
      <column caption='Store Type of selected Store' datatype='string' name='[Calculation_1602718552925081602]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='{MAX(If [Store Filter (copy)_1756403905605222402] THEN  [Store Type] END)}' />
      </column>
      <column caption='Is Business Line of selected Product?' datatype='boolean' name='[Calculation_1602718552925458435 1]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Product Line] = [Calculation_1602718552925081602 1]' />
      </column>
      <column caption='Is Store Type of selected Store?' datatype='boolean' name='[Calculation_1602718552925458435]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Store Type] = [Calculation_1602718552925081602]' />
      </column>
      <column caption='Rank Total Sales (selected store)' datatype='integer' default-format='n&quot;#&quot;#,##0;-&quot;#&quot;#,##0' name='[Calculation_1602718552946008073]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Count the distinct number of stores&#13;&#10;// where Store&apos;s [Total Sales] &gt; Selected Store [Total Sales]&#13;&#10;COUNTD(if {INCLUDE [Store] : [LinPack_259808385027569986]} &gt; {MAX((IF [Store Filter (copy)_1756403905605222402] THEN {INCLUDE [Store] : ZN([LinPack_259808385027569986])} ELSE 0 END))}&#13;&#10;       and Not [Store Filter (copy)_1756403905605222402]&#13;&#10;       then [Store]  end)+1' />
      </column>
      <column caption='Selected Store' datatype='string' name='[Calculation_1602718553031667727]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Store Filter (copy)_1756403905605222402] THEN [Store] END' />
      </column>
      <column caption='Total Sales Perf. - Value (Avg per store)' datatype='real' default-format='n#,##0,K;-#,##0,K' name='[Calculation_401664827423084549]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[LinPack_259808385027569986]/ AVG({[LinPack_357404440564501587]})' />
      </column>
      <column caption='MARKET SHARE TOTAL' datatype='real' name='[Calculation_416583030138216452]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='float(MAX(1.0))' />
        <desc>
          <formatted-text>
            <run>→</run>
          </formatted-text>
        </desc>
      </column>
      <column caption='Total Sales Perf. - Value vs Reference (Abs)' datatype='real' name='[Calculation_845550866686230533]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ABS([LinPack_216324288650019298])' />
      </column>
      <column caption='Product Filter' datatype='string' name='[Calculation_949978112673886208]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Product]' />
        <desc>
