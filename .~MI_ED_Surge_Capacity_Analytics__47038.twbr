              <run bold='true'>Inventory</run>
              <run>: </run>
              <run auto-url='true' hyperlink='tabdoc:load-url url=&amp;quot;https://exchange.tableau.com/products/576&amp;quot;'>https://exchange.tableau.com/products/576</run>
              <run>&#10;     - </run>
              <run bold='true'>Stock Coverage (ABC-XYZ)</run>
              <run>: </run>
              <run auto-url='true' hyperlink='tabdoc:load-url url=&amp;quot;https://exchange.tableau.com/products/577&amp;quot;'>https://exchange.tableau.com/products/577</run>
              <run>&#10;     - </run>
              <run bold='true'>Logistic Shipment</run>
              <run>: </run>
              <run auto-url='true' hyperlink='tabdoc:load-url url=&amp;quot;https://exchange.tableau.com/products/578&amp;quot;'>https://exchange.tableau.com/products/578</run>
              <run>Æ&#10;&#10;</run>
              <run bold='true' fontcolor='#2b5c8a' fontsize='10'>Procurement</run>
              <run>&#10;     - </run>
              <run bold='true'>Purchasing</run>
              <run>: </run>
              <run auto-url='true' hyperlink='tabdoc:load-url url=&amp;quot;https://exchange.tableau.com/products/540&amp;quot;'>https://exchange.tableau.com/products/540</run>
              <run>&#10;     - </run>
