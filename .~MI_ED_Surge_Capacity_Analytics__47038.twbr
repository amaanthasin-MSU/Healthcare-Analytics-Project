            <column caption='Total Sales Perf. - Reference' datatype='real' default-format='c&quot;$ &quot;#,##0;(&quot;$ &quot;#,##0)' name='[LinPack_027668641002889090]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [Parameters].[LinPack_949819255619347265] &#13;&#10;WHEN &quot;CM_vs_PM&quot; THEN [LinPack_652671893335368817] &#13;&#10;WHEN &quot;CM_vs_PY&quot; THEN [LinPack_505925252748652169] &#13;&#10;WHEN &quot;ACT_vs_TGT&quot; THEN NULL &#13;&#10;WHEN &quot;CYTD_vs_PYTD&quot; THEN [LinPack_645716681244502966] &#13;&#10;WHEN &quot;YTDACT_vs_YTDTGT&quot; THEN NULL &#13;&#10;WHEN &quot;NONE&quot;  THEN NULL &#13;&#10;END' />
              <desc>
                <formatted-text>
                  <run>Total Sales Perf. - Reference: &apos;Total Sales&apos; value for Previous Period, Previous Period or target depending on user choice in &apos;Performance Scope&apos; selector</run>
                </formatted-text>
              </desc>
            </column>
            <column caption='Total Sales  MTD   (Current Month)' datatype='real' default-format='c&quot;$ &quot;#,##0;(&quot;$ &quot;#,##0)' name='[LinPack_074081860109431474]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF [LinPack_112320563205440314] = [Parameters].[LinPack_661713406488724115] AND [LinPack_923155276951376517] = [Parameters].[LinPack_268298139370622864] THEN [LinPack_722828940895585291] ELSE NULL END)' />
              <desc>
                <formatted-text>
                  <run>Total Sales  MTD   (Current Month): Month-to-Date &apos;Total Sales&apos; value for selected current Month</run>
                </formatted-text>
              </desc>
            </column>
            <column caption='Total Sales Perf. - Value vs Reference %' datatype='real' default-format='*+0.0%;-0.0%;=' name='[LinPack_108811525029580986]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[LinPack_216324288650019298] / ABS([LinPack_027668641002889090])' />
              <desc>
                <formatted-text>
                  <run>Total Sales Perf. - Value vs Reference %: Difference % between &apos;Total Sales&apos; Value and Reference, depending on user choice in &apos;Performance Scope&apos;</run>
                </formatted-text>
              </desc>
            </column>
            <column caption='Main Date: Year' datatype='integer' default-format='n0;-0' name='[LinPack_112320563205440314]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='YEAR([Date])' />
              <desc>
                <formatted-text>
                  <run>Main Date: Year: Returns the year of the date used for time series calculations in the data source [numeric format]</run>
                </formatted-text>
              </desc>
            </column>
            <column caption='Total Sales Perf. - Value vs Reference' datatype='real' default-format='*+&quot;$ &quot;#,##0;-&quot;$ &quot;#,##0;=' name='[LinPack_216324288650019298]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='ZN([LinPack_259808385027569986]) - ZN([LinPack_027668641002889090])' />
              <desc>
                <formatted-text>
                  <run>Total Sales Perf. - Value vs Reference: Difference between &apos;Total Sales&apos; Value and Reference, depending on user choice in &apos;Performance Scope&apos;</run>
                </formatted-text>
              </desc>
            </column>
