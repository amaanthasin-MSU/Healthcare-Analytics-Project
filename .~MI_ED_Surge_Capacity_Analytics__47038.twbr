            <column caption='Total Sales Perf. - Value vs Reference (shape)' datatype='string' name='[LinPack_935575415602653404]' role='measure' type='nominal'>
              <calculation class='tableau' formula='CASE sign([LinPack_216324288650019298]) &#13;&#10;WHEN 1 THEN &#13;&#10;    IF [Parameters].[LinPack_949819255619347265]= &quot;ACT_vs_TGT&quot; OR [Parameters].[LinPack_949819255619347265]= &quot;YTDACT_vs_YTDTGT&quot; THEN &quot;●&quot; &#13;&#10;    ELSE &quot;▲&quot; &#13;&#10;    END &#13;&#10;WHEN 0 THEN &#13;&#10;    IF [Parameters].[LinPack_949819255619347265]= &quot;ACT_vs_TGT&quot; OR [Parameters].[LinPack_949819255619347265]= &quot;YTDACT_vs_YTDTGT&quot; THEN &quot; &quot; &#13;&#10;    ELSE &quot;►&quot; &#13;&#10;    END &#13;&#10;WHEN -1 THEN &#13;&#10;    IF [Parameters].[LinPack_949819255619347265]= &quot;ACT_vs_TGT&quot; OR [Parameters].[LinPack_949819255619347265]= &quot;YTDACT_vs_YTDTGT&quot; THEN &quot;■&quot; &#13;&#10;    ELSE &quot;▼&quot; &#13;&#10;    END &#13;&#10;ELSE &quot; &quot; &#13;&#10;END' />
              <desc>
                <formatted-text>
