            <column datatype='datetime' name='[Date]' role='dimension' type='ordinal'>
              <desc>
                <formatted-text>
                  <run>Date</run>
                </formatted-text>
              </desc>
            </column>
            <column caption='Main Date: Year' datatype='integer' default-format='n0;-0' name='[LinPack_112320563205440314]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='YEAR([Date])' />
              <desc>
                <formatted-text>
                  <run>Main Date: Year: Returns the year of the date used for time series calculations in the data source [numeric format]</run>
                </formatted-text>
              </desc>
            </column>
            <column caption='Filter: Performance Trend' datatype='string' name='[LinPack_435762884483396056]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='CASE [Parameters].[LinPack_949819255619347265] &#13;&#10;WHEN &quot;CM_vs_PM&quot;  THEN IF [LinPack_782981515852570131] &lt;= 0 AND [LinPack_782981515852570131] &gt;= -12 THEN &quot;Y&quot; ELSE &quot;N&quot; END &#13;&#10;WHEN &quot;CM_vs_PY&quot;  THEN IF [LinPack_112320563205440314] = [Parameters].[LinPack_661713406488724115] OR [LinPack_112320563205440314] = [Parameters].[LinPack_661713406488724115]-1 THEN &quot;Y&quot; ELSE &quot;N&quot; END &#13;&#10;WHEN &quot;ACT_vs_TGT&quot;  THEN IF [LinPack_112320563205440314] = [Parameters].[LinPack_661713406488724115] THEN &quot;Y&quot; ELSE &quot;N&quot; END &#13;&#10;WHEN &quot;CYTD_vs_PYTD&quot;  THEN IF [LinPack_112320563205440314] = [Parameters].[LinPack_661713406488724115] OR [LinPack_112320563205440314] = [Parameters].[LinPack_661713406488724115]-1 THEN &quot;Y&quot; ELSE &quot;N&quot; END &#13;&#10;WHEN &quot;YTDACT_vs_YTDTGT&quot;  THEN IF [LinPack_112320563205440314] = [Parameters].[LinPack_661713406488724115] THEN &quot;Y&quot; ELSE &quot;N&quot; END &#13;&#10;WHEN &quot;NONE&quot;  THEN NULL &#13;&#10;END' />
              <desc>
                <formatted-text>
                  <run>Filter: Performance Trend: Filter to use when showing performance evolution</run>
                </formatted-text>
              </desc>
            </column>
            <column caption='Total Sales' datatype='real' default-format='c&quot;$ &quot;#,##0;(&quot;$ &quot;#,##0)' name='[LinPack_669617259505915387]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([LinPack_722828940895585291])' />
              <desc>
                <formatted-text>
                  <run>Total Sales: &apos;Total Sales&apos; value (numeric format)</run>
                </formatted-text>
              </desc>
            </column>
            <column caption='_Total Sales (Expression)' datatype='real' name='[LinPack_722828940895585291]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[Sales Amount]' />
              <desc>
                <formatted-text>
                  <run>_Total Sales (Expression): &apos;Total Sales&apos; expression (used in other KPI calculations, no aggregation rule)</run>
                </formatted-text>
              </desc>
            </column>
            <column caption='Period: Months to Current Month' datatype='integer' name='[LinPack_782981515852570131]' role='dimension' type='quantitative'>
              <calculation class='tableau' formula='-1*(([Parameters].[LinPack_661713406488724115]- [LinPack_112320563205440314])*12+([Parameters].[LinPack_268298139370622864] - [LinPack_923155276951376517]))' />
              <desc>
                <formatted-text>
                  <run>Period: Months to Current Month: Returns the number of Months between the selected Current Month and the reference date of the data source</run>
                </formatted-text>
              </desc>
            </column>
            <column caption='Main Date: Month of Last Date' datatype='integer' name='[LinPack_824770257087054660]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{fixed: max(month( {fixed:max([Date])}))}' />
              <desc>
                <formatted-text>
                  <run>Main Date: Month of Last Date: Returns the Month of Last Date</run>
                </formatted-text>
              </desc>
            </column>
            <column caption='Period: Analysis Scope Type' datatype='string' name='[LinPack_896518324215743631]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[Parameters].[LinPack_949819255619347265]' />
              <desc>
                <formatted-text>
                  <run>Period: Analysis Scope Type: Returns the type of performance analyzed</run>
                </formatted-text>
              </desc>
            </column>
            <column caption='Main Date: Year of Last Date' datatype='integer' name='[LinPack_910880770100488739]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{fixed: max(year( {fixed:max([Date])}))}' />
              <desc>
                <formatted-text>
                  <run>Main Date: Year of Last Date: Returns the Year of Last Date</run>
                </formatted-text>
