            <column caption='Filter: Performance KPI' datatype='string' name='[LinPack_201814955039210740]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='CASE [Parameters].[LinPack_949819255619347265] &#13;&#10;WHEN &quot;CM_vs_PM&quot;  THEN IF [LinPack_782981515852570131] = 0 OR [LinPack_782981515852570131] = -1 THEN &quot;Y&quot; ELSE &quot;N&quot; END &#13;&#10;WHEN &quot;CM_vs_PY&quot;  THEN IF [LinPack_782981515852570131] = 0 OR [LinPack_782981515852570131] = -12 THEN &quot;Y&quot; ELSE &quot;N&quot; END &#13;&#10;WHEN &quot;ACT_vs_TGT&quot;  THEN IF [LinPack_782981515852570131] = 0 THEN &quot;Y&quot; ELSE &quot;N&quot; END &#13;&#10;WHEN &quot;CYTD_vs_PYTD&quot;  THEN IF ([LinPack_112320563205440314] = [Parameters].[LinPack_661713406488724115] OR [LinPack_112320563205440314] = [Parameters].[LinPack_661713406488724115]-1) AND [LinPack_923155276951376517] &lt;= [Parameters].[LinPack_268298139370622864] THEN &quot;Y&quot; ELSE &quot;N&quot; END &#13;&#10;WHEN &quot;YTDACT_vs_YTDTGT&quot;  THEN IF [LinPack_112320563205440314] = [Parameters].[LinPack_661713406488724115] AND [LinPack_923155276951376517] &lt;= [Parameters].[LinPack_268298139370622864] THEN &quot;Y&quot; ELSE &quot;N&quot; END &#13;&#10;WHEN &quot;NONE&quot;  THEN NULL &#13;&#10;END' />
              <desc>
