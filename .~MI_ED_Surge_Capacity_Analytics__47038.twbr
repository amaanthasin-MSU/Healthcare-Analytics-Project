              <run bold='true'>Sales Market Share</run>
              <run>: </run>
              <run auto-url='true' hyperlink='tabdoc:load-url url=&amp;quot;https://exchange.tableau.com/products/819&amp;quot;'>https://exchange.tableau.com/products/819</run>
              <run>&#10;     - </run>
              <run bold='true'>Salesforce Consumer Goods Cloud Key Account Management</run>
              <run>: </run>
              <run auto-url='true' hyperlink='tabdoc:load-url url=&amp;quot;https://exchange.tableau.com/products/822&amp;quot;'>https://exchange.tableau.com/products/822</run>
              <run>Æ&#10;&#10;</run>
              <run bold='true' fontcolor='#2b5c8a' fontsize='10'>Marketing</run>
              <run>&#10;     - </run>
              <run bold='true'>Email Marketing Campaigns</run>
              <run>: </run>
              <run auto-url='true' hyperlink='tabdoc:load-url url=&amp;quot;https://exchange.tableau.com/products/614&amp;quot;'>https://exchange.tableau.com/products/614</run>
              <run>&#10;     - </run>
              <run bold='true'>Google Analytics</run>
              <run>: </run>
              <run auto-url='true' hyperlink='tabdoc:load-url url=&amp;quot;https://exchange.tableau.com/products/545&amp;quot;'>https://exchange.tableau.com/products/545</run>
              <run>&#10;     - </run>
              <run bold='true'>Google Ads</run>
              <run>: </run>
              <run auto-url='true' hyperlink='tabdoc:load-url url=&amp;quot;https://exchange.tableau.com/products/546&amp;quot;'>https://exchange.tableau.com/products/546</run>
              <run>Æ&#10;&#10;</run>
              <run bold='true' fontcolor='#2b5c8a' fontsize='10'>Supply Chain</run>
              <run>&#10;     - </run>
              <run bold='true'>Supply Intelligence</run>
              <run>: </run>
              <run auto-url='true' hyperlink='tabdoc:load-url url=&amp;quot;https://exchange.tableau.com/products/694&amp;quot;'>https://exchange.tableau.com/products/694</run>
