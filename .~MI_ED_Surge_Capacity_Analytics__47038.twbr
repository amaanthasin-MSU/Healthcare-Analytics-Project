            <column caption='Period: Name of Current Month' datatype='string' name='[LinPack_757358447910608516]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[LinPack_252784880429080528] + &quot;-&quot; + RIGHT(STR([Parameters].[LinPack_661713406488724115]),2)' />
