  <worksheets>
    <worksheet name='Avg sales title (for Selected Store)'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontname='Tableau Bold' fontsize='8'>Total Sales &amp; {%%KPI3.label%%} by Product Line</run>
          </formatted-text>
        </title>
        <caption>
          <formatted-text>
            <run bold='true' fontcolor='#555555' fontname='Tableau Regular' fontsize='7'>Total Sales</run>
            <run>Æ&#10;</run>
            <run fontcolor='#898989' fontname='Tableau Regular' fontsize='7'>Current Period</run>
          </formatted-text>
        </caption>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Retail Sales Data Extract' name='federated.0yylszc1nyju5o130dues14408ct' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column _.fcp.ParameterDefaultValues.true...default-value-field='[federated.0yylszc1nyju5o130dues14408ct].[LinPack_824770257087054660]' alias='Dec' caption='Current Month' datatype='integer' folder-name='Current Period' name='[LinPack_268298139370622864]' param-domain-type='list' role='measure' type='quantitative' value='12'>
              <calculation class='tableau' formula='12' />
              <aliases>
                <alias key='1' value='Jan' />
                <alias key='2' value='Feb' />
                <alias key='3' value='Mar' />
                <alias key='4' value='Apr' />
                <alias key='5' value='May' />
                <alias key='6' value='Jun' />
                <alias key='7' value='Jul' />
                <alias key='8' value='Aug' />
                <alias key='9' value='Sep' />
                <alias key='10' value='Oct' />
                <alias key='11' value='Nov' />
                <alias key='12' value='Dec' />
              </aliases>
              <desc>
                <formatted-text>
                  <run>Current Month: Allows to pick-up Current Month</run>
                </formatted-text>
              </desc>
            </column>
            <column _.fcp.ParameterDefaultValues.true...default-value-field='[federated.0yylszc1nyju5o130dues14408ct].[LinPack_910880770100488739]' _.fcp.ParameterDefaultValues.true...source-field='[federated.0yylszc1nyju5o130dues14408ct].[LinPack_112320563205440314]' caption='Current Year' datatype='integer' default-format='n0;-0' folder-name='Current Period' name='[LinPack_661713406488724115]' param-domain-type='list' role='measure' type='quantitative' value='2023'>
              <calculation class='tableau' formula='2023' />
              <desc>
                <formatted-text>
                  <run>Current Year: Allows to pick-up Current Year</run>
                </formatted-text>
              </desc>
            </column>
            <column alias='Year-to-Date: Current Year vs Previous Year' caption='Performance Scope' datatype='string' folder-name='&gt; Global Parameters' name='[LinPack_949819255619347265]' param-domain-type='list' role='measure' type='nominal' value='&quot;CYTD_vs_PYTD&quot;'>
              <calculation class='tableau' formula='&quot;CYTD_vs_PYTD&quot;' />
              <aliases>
                <alias key='&quot;CM_vs_PM&quot;' value='Current Month vs Previous Month' />
                <alias key='&quot;CM_vs_PY&quot;' value='Current Month vs Same Month, Previous Year' />
                <alias key='&quot;CYTD_vs_PYTD&quot;' value='Year-to-Date: Current Year vs Previous Year' />
              </aliases>
