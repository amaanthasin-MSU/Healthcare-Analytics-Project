              <calculation class='tableau' formula='SUM(IF [LinPack_112320563205440314] = [LinPack_782425746069905057] AND [LinPack_923155276951376517] = [LinPack_666004502180379296] THEN [LinPack_722828940895585291] ELSE NULL END)' />
