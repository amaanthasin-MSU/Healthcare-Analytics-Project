    <worksheet name='Perf - Market Share Trend MTD (for Selected Product)'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontname='Tableau Bold' fontsize='8'>Total Sales &amp; {%%KPI3.label%%} by Product Line</run>
          </formatted-text>
