              <calculation class='tableau' formula='SUM(IF [LinPack_112320563205440314] = [Parameters].[LinPack_661713406488724115] - 1 AND [LinPack_923155276951376517] &lt;= [Parameters].[LinPack_268298139370622864] THEN [LinPack_722828940895585291] ELSE NULL END)' />
