            <column _.fcp.ParameterDefaultValues.true...default-value-field='[federated.0yylszc1nyju5o130dues14408ct].[LinPack_910880770100488739]' _.fcp.ParameterDefaultValues.true...source-field='[federated.0yylszc1nyju5o130dues14408ct].[LinPack_112320563205440314]' caption='Current Year' datatype='integer' default-format='n0;-0' folder-name='Current Period' name='[LinPack_661713406488724115]' param-domain-type='list' role='measure' type='quantitative' value='2023'>
