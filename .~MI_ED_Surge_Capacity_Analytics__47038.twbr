            <column caption='Total Sales' datatype='real' default-format='c&quot;$ &quot;#,##0;(&quot;$ &quot;#,##0)' name='[LinPack_669617259505915387]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([LinPack_722828940895585291])' />
              <desc>
