            <column alias='Year-to-Date: Current Year vs Previous Year' caption='Performance Scope' datatype='string' folder-name='&gt; Global Parameters' name='[LinPack_949819255619347265]' param-domain-type='list' role='measure' type='nominal' value='&quot;CYTD_vs_PYTD&quot;'>
              <calculation class='tableau' formula='&quot;CYTD_vs_PYTD&quot;' />
              <aliases>
                <alias key='&quot;CM_vs_PM&quot;' value='Current Month vs Previous Month' />
                <alias key='&quot;CM_vs_PY&quot;' value='Current Month vs Same Month, Previous Year' />
                <alias key='&quot;CYTD_vs_PYTD&quot;' value='Year-to-Date: Current Year vs Previous Year' />
              </aliases>
              <desc>
                <formatted-text>
                  <run>Performance Scope: Allows to pick-up the type of performance to analyze: Current Month vs Previous Month, Current Month vs Same Month Previous Year, Current Month: Actual vs Target, Year-to-Date: Current Year vs Previous Year, Year-to-Date: Actual vs Target</run>
                </formatted-text>
