            <column caption='Total Sales Perf. -  Value (for trends)' datatype='real' default-format='c&quot;$ &quot;#,##0;(&quot;$ &quot;#,##0)' name='[LinPack_281759258806095663]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF ATTR([LinPack_923155276951376517]) &lt;= [Parameters].[LinPack_268298139370622864] THEN &#13;&#10;CASE [Parameters].[LinPack_949819255619347265] &#13;&#10;WHEN &quot;CM_vs_PM&quot; THEN NULL &#13;&#10;WHEN &quot;CM_vs_PY&quot; THEN [LinPack_868209407977428119] &#13;&#10;WHEN &quot;ACT_vs_TGT&quot; THEN  [LinPack_868209407977428119] &#13;&#10;WHEN &quot;CYTD_vs_PYTD&quot; THEN [LinPack_949807225544088058] &#13;&#10;WHEN &quot;YTDACT_vs_YTDTGT&quot; THEN [LinPack_949807225544088058]  &#13;&#10;WHEN &quot;NONE&quot;  THEN NULL &#13;&#10;END &#13;&#10;END'>
                <table-calc ordering-type='Rows' />
              </calculation>
              <desc>
                <formatted-text>
                  <run>Total Sales Perf. -  Value (for trends): &apos;Total Sales&apos; value for current Month or current year depending on user choice in &apos;Performance Scope&apos; selector [to be used in trends charts]</run>
                </formatted-text>
              </desc>
            </column>
            <column caption='Period: Period of Reference (for trends)' datatype='string' name='[LinPack_396658189945445221]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='CASE [Parameters].[LinPack_949819255619347265] &#13;&#10;WHEN &quot;CM_vs_PM&quot;  THEN NULL &#13;&#10;WHEN &quot;CM_vs_PY&quot;  THEN STR([Parameters].[LinPack_661713406488724115]-1) &#13;&#10;WHEN &quot;ACT_vs_TGT&quot;  THEN &quot;Target &quot; + STR([Parameters].[LinPack_661713406488724115]) &#13;&#10;WHEN &quot;CYTD_vs_PYTD&quot;  THEN &quot;YTD &quot; + STR([Parameters].[LinPack_661713406488724115]-1) &#13;&#10;WHEN &quot;YTDACT_vs_YTDTGT&quot;  THEN &quot;YTD &quot; + STR([Parameters].[LinPack_661713406488724115]) + &quot; Target&quot; &#13;&#10;WHEN &quot;NONE&quot;  THEN NULL &#13;&#10;END' />
              <desc>
