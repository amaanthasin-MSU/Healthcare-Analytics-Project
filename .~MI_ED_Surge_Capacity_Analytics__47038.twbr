              <calculation class='tableau' formula='CASE [Parameters].[LinPack_268298139370622864] &#13;&#10;WHEN 2 THEN &quot;Jan&quot; &#13;&#10;WHEN 3 THEN &quot;Feb&quot; &#13;&#10;WHEN 4 THEN &quot;Mar&quot; &#13;&#10;WHEN 5 THEN &quot;Apr&quot; &#13;&#10;WHEN 6 THEN &quot;May&quot; &#13;&#10;WHEN 7 THEN &quot;Jun&quot; &#13;&#10;WHEN 8 THEN &quot;Jul&quot; &#13;&#10;WHEN 9 THEN &quot;Aug&quot; &#13;&#10;WHEN 10 THEN &quot;Sep&quot; &#13;&#10;WHEN 11 THEN &quot;Oct&quot; &#13;&#10;WHEN 12 THEN &quot;Nov&quot; &#13;&#10;WHEN 1 THEN &quot;Dec&quot; &#13;&#10;END' />
              <desc>
                <formatted-text>
                  <run>Period: Month Name of Previous Month: Month Name of Previous Month</run>
                </formatted-text>
              </desc>
            </column>
            <column caption='Main Date: Month of Last Date' datatype='integer' name='[LinPack_824770257087054660]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{fixed: max(month( {fixed:max([Date])}))}' />
              <desc>
                <formatted-text>
                  <run>Main Date: Month of Last Date: Returns the Month of Last Date</run>
                </formatted-text>
              </desc>
            </column>
            <column caption='Period: Period of Reference' datatype='string' name='[LinPack_892651223732788740]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='CASE [Parameters].[LinPack_949819255619347265] &#13;&#10;WHEN &quot;CM_vs_PM&quot;  THEN [LinPack_700028686822366886] &#13;&#10;WHEN &quot;CM_vs_PY&quot;  THEN [LinPack_934859979600727254] &#13;&#10;WHEN &quot;ACT_vs_TGT&quot;  THEN &quot;Target &quot; + [LinPack_757358447910608516] &#13;&#10;WHEN &quot;CYTD_vs_PYTD&quot;  THEN &quot;YTD &quot; + [LinPack_934859979600727254] &#13;&#10;WHEN &quot;YTDACT_vs_YTDTGT&quot;  THEN &quot;YTD &quot; + [LinPack_757358447910608516] + &quot; Target&quot; &#13;&#10;WHEN &quot;NONE&quot;  THEN NULL &#13;&#10;END' />
              <desc>
                <formatted-text>
                  <run>Period: Period of Reference: Returns the period which is used as a reference (eg &apos;YTD Mar-17&apos;)</run>
                </formatted-text>
              </desc>
            </column>
            <column caption='Main Date: Year of Last Date' datatype='integer' name='[LinPack_910880770100488739]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{fixed: max(year( {fixed:max([Date])}))}' />
              <desc>
                <formatted-text>
                  <run>Main Date: Year of Last Date: Returns the Year of Last Date</run>
                </formatted-text>
              </desc>
            </column>
            <column caption='Main Date: Month' datatype='integer' default-format='n0;-0' name='[LinPack_923155276951376517]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='MONTH([Date])' />
              <desc>
                <formatted-text>
                  <run>Main Date: Month: Returns the Month of the date used for time series calculations in the data source [numeric format]</run>
                </formatted-text>
              </desc>
            </column>
            <column caption='Period: Name of Same Month Previous Year' datatype='string' name='[LinPack_934859979600727254]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[LinPack_252784880429080528] + &quot;-&quot; + RIGHT(STR([Parameters].[LinPack_661713406488724115]-1),2)' />
              <desc>
                <formatted-text>
