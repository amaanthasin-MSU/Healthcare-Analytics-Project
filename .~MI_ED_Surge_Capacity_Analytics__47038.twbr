            <column caption='Period: Period Analyzed (for trends)' datatype='string' name='[LinPack_477135843804997627]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='CASE [Parameters].[LinPack_949819255619347265] &#13;&#10;WHEN &quot;CM_vs_PM&quot;  THEN NULL &#13;&#10;WHEN &quot;CM_vs_PY&quot;  THEN STR([Parameters].[LinPack_661713406488724115]) &#13;&#10;WHEN &quot;ACT_vs_TGT&quot;  THEN &quot;Actual &quot; + STR([Parameters].[LinPack_661713406488724115]) &#13;&#10;WHEN &quot;CYTD_vs_PYTD&quot;  THEN &quot;YTD &quot; + STR([Parameters].[LinPack_661713406488724115]) &#13;&#10;WHEN &quot;YTDACT_vs_YTDTGT&quot;  THEN &quot;YTD &quot; + STR([Parameters].[LinPack_661713406488724115]) + &quot; Actual&quot; &#13;&#10;WHEN &quot;NONE&quot;  THEN NULL &#13;&#10;END' />
