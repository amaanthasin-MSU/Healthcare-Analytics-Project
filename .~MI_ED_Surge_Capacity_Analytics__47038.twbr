            <column caption='Filter: Performance Card' datatype='string' name='[LinPack_788695428445931252]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [LinPack_782981515852570131] &lt;= 0 AND [LinPack_782981515852570131] &gt;= -24 THEN &quot;Y&quot; ELSE &quot;N&quot; END' />
